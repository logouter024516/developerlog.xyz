# Supabase Configuration (Realtime 전용)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# GitHub Configuration
VITE_GITHUB_USERNAME=your_github_username
VITE_GITHUB_TOKEN=your_github_personal_access_token  # Required: Private 레포 + rate limit 증가
VITE_GITHUB_REPO_NAME=03_portfolio_web  # 이 포트폴리오 레포지토리 이름

# Admin Panel (GUI 레포 필터링)
VITE_ADMIN_PASSWORD=admin123  # Admin 페이지 비밀번호 (/admin 접속 시 필요)

# Repository Filtering (선택적 - GUI가 우선, 환경변수는 fallback)
# 콤마로 구분, 예: "repo1,repo2,repo3"
VITE_GITHUB_SHOW_ONLY_REPOS=  # 설정 시 이 레포들만 표시
VITE_GITHUB_HIDE_REPOS=       # 특정 레포 숨기기
